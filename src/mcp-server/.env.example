# MCP Server 環境変数設定例
# このファイルをコピーして .env を作成し、実際の値を設定してください
# .env は .gitignore に含まれており、リポジトリにコミットされません

# ──────────────────────────────────────────────
# Azure SQL Database
# ──────────────────────────────────────────────
SQL_SERVER=<your-server-name>.database.windows.net
SQL_DATABASE=<your-database-name>
# Managed Identity を使用するため SQL_USER / SQL_PASSWORD は不要

# ──────────────────────────────────────────────
# Azure AI Search
# ──────────────────────────────────────────────
AI_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AI_SEARCH_INDEX=metadata-index
# AI_SEARCH_API_KEY は Managed Identity 使用時不要（開発時にのみ設定）
# AI_SEARCH_API_KEY=<api-key>

# ──────────────────────────────────────────────
# Azure Application Insights
# ──────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://japaneast-1.in.applicationinsights.azure.com/;LiveEndpoint=https://japaneast.livediagnostics.monitor.azure.com/

# ──────────────────────────────────────────────
# サーバ設定
# ──────────────────────────────────────────────
PORT=8000

# ──────────────────────────────────────────────
# ローカル開発用 (Azure 接続なしで動作確認)
# ──────────────────────────────────────────────
# 以下を "true" にすると Azure サービス接続をスキップ
# USE_LOCAL_METADATA=true
